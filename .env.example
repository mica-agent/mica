# Mica — environment configuration
#
# Copy to `.env` in one of two locations (the server loads both, with the
# workspace one taking precedence over the repo one; ambient env wins over
# both):
#   <PROJECT_DIR>/.env   — typical for Docker deployments (workspace root)
#   <repo-root>/.env     — typical for local dev checkouts
#
# Nothing is required — everything has sensible defaults. Set only what you
# want to override.

# ─── Ports ───────────────────────────────────────────────────────────────
# MICA_PORT=3002              # backend API
# MICA_FRONTEND_PORT=5173     # vite dev server

# ─── Workspace ───────────────────────────────────────────────────────────
# PROJECT_DIR=/workspaces/testproj     # where projects live on disk
# MICA_SHARED_DIR=/workspaces/shared   # workspace-shared docs dir
                                       #   (browsed by .shared-library cards,
                                       #    pinnable via mica_pin_shared_doc).

# ─── Inference: local (vLLM primary, llama-server fallback) ──────────────
# Chat agent inference defaults to the bundled vLLM container at
# 127.0.0.1:8012. If you want the rollback llama-server path instead, set
# MICA_DISABLE_CHAT_VLLM=1 AND unset MICA_DISABLE_LLAMA so the backend
# spawns llama-server. See scripts/start.sh for the topology toggles.
#
# MICA_DISABLE_CHAT_VLLM=1    # skip the chat vLLM container (frontend-only iter)
# MICA_DISABLE_LLAMA=1        # skip local llama-server entirely (OpenRouter-only)
#
# llama-server-specific knobs (apply when llama-server is the active path):
# LLAMA_BIN=llama-server                   # override binary path / name on PATH
# LLAMA_HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
# LLAMA_HF_FILE=Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf
# LLAMA_MMPROJ=/path/to/mmproj-F16.gguf    # override auto-detect
# MODEL_PATH=/absolute/path/to/your.gguf   # bypass HF resolution entirely
# LLAMA_CTX_SIZE=131072       # per-slot context (KV = np × this; default 128K)
# LLAMA_N_PARALLEL=3          # parallel decoding slots
# LLAMA_CACHE_RAM=16384       # host-memory prompt cache (MiB). "0" disables, "-1" unlimited.
# LLAMA_LOG_FILE=/workspaces/.mica-llama-server.log
# LLAMA_URL=http://127.0.0.1:8012    # override if llama-server runs elsewhere

# ─── Inference: OpenRouter (cloud) ───────────────────────────────────────
# Each chat card's gear menu can override these per-project — that wins.
# Workspace values here are the cross-project fallback.
# OPENROUTER_API_KEY=sk-or-v1-…
# Default model used when a chat card is set to provider=openrouter and
# the card settings don't pin a specific model.
# OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# ─── Inference: OpenAI-compatible endpoint ───────────────────────────────
# Powers the "OpenAI-compatible" provider radio in chat cards (route to a
# self-hosted vLLM elsewhere, Together, Groq, your own deployment). Same
# precedence as OpenRouter — per-card setting wins.
# OPENAI_API_KEY=sk-…
# OPENAI_BASE_URL=https://your-endpoint.example.com/v1

# ─── Inference: Claude (Anthropic) ───────────────────────────────────────
# .claude cards spawn the Claude Code CLI, which reads its own credentials
# from ~/.claude/.credentials.json — no key needed here. Only set the
# model override if you want to pin a specific id rather than the SDK
# default.
# ANTHROPIC_MODEL=claude-opus-4-1

# ─── Web search (Tavily MCP) ─────────────────────────────────────────────
# qwen-code's built-in web_search tool was removed upstream in CLI v0.15.2
# (PR #3502); search is now MCP-based. When TAVILY_API_KEY is set, the
# server registers tavily-mcp as an MCP server alongside mica-builtins,
# exposing tavily-search / tavily-extract / tavily-crawl / tavily-map to
# the agent. Without it, the agent has no search capability — only the
# built-in web_fetch tool, which requires a known URL up front.
#
# TAVILY_API_KEY=tvly-...              # https://tavily.com (1k free/mo)

# ─── GitHub ──────────────────────────────────────────────────────────────
# Powers `gh` CLI calls from .terminal cards and the project-clone flow.
# Easiest path: open a .terminal card and run `gh auth login`. As a
# fallback, set one of these env vars and `gh` / direct API calls will
# pick it up. The Connections panel surfaces which method is active.
# GH_TOKEN=ghp_…
# GITHUB_TOKEN=ghp_…

# ─── Voice (Parakeet STT, Kokoro TTS) ────────────────────────────────────
# Sidecars auto-spawn on first .voice card request. Override only when
# running the sidecars on a different host.
# MICA_DISABLE_VOICE=1        # skip voice sidecars entirely
# MICA_VOICE_AMBIENT=0        # globally suppress ambient announcements
#                             # (each card also has its own auto-read toggle)
# MICA_VOICE_SDK=1            # opt into Vercel AI SDK + vLLM native function
#                             # calling path (legacy XML protocol otherwise)
# VOICE_STT_HOST=127.0.0.1
# VOICE_STT_PORT=8013
# VOICE_TTS_HOST=127.0.0.1
# VOICE_TTS_PORT=8014
# VOICE_TTS_VOICE=af_bella    # see scripts/sidecars/voice-tts-server.py
                              # for the catalog (af_/am_ = American English voices)
